# Mac Photo Sync → Immich
# 複製到 ~/.config/immich-apps/photo-sync.config.yaml 後依本機路徑修改
#
# SSOT：Mac 上的 .photoslibrary（不在 Immich 刪除後回寫 Mac）
# Immich：兩個 library 的 union + dedupe（CLI 依 hash）

immich:
  instance_url: https://immich.3q.fi
  # api_key 建議用環境變數 IMMICH_API_KEY（1Password load-env-from-op.sh）

# 暫存目錄（可選；預設 /tmp/immich-photo-sync）
# staging_dir: /tmp/immich-photo-sync

libraries:
  - id: icloud-primary
    name: Photos Library
    path: ~/Pictures/Photos Library.photoslibrary/originals
    album: Mac Photos (iCloud)
    tags:
      - mac-sync
      - icloud-library
    enabled: true

  - id: local-archive
    name: LOCAL PHOTO LIBRARY
    path: ~/Pictures/LOCAL PHOTO LIBRARY.photoslibrary/originals
    album: Mac Photos (Local Archive)
    tags:
      - mac-sync
      - local-library
    enabled: true

# iCloud library 容量分層（Phase 3.5 — 需 osxphotos / Photos API，尚未自動化）
# 目的：iCloud 空間有限時，舊照片移到 local-archive library，兩邊仍同步到 Immich
tier_policy:
  enabled: false
  source_library_id: icloud-primary
  target_library_id: local-archive
  # 二擇一或同時（超出任一條件即 eligible）
  max_size_gb: 50
  cutoff_date: "2023-01-01"   # PoC: tier-policy-poc.sh 預設讀此欄位
  dry_run: true
  batch_size: 10
  local_path_only: true
  skip_shared_library: false
  import_mode: manual         # manual | auto — manual 較穩（Photos GUI import）
  import_to_album: false       # false = 不指定 album，減少 AppleScript 卡住
  # staging_dir: /tmp/immich-photo-sync/tier-staging

sync:
  recursive: true
  upload_mode: api              # api（Photos 日期）| cli（legacy immich upload）
  timezone_default: Asia/Taipei
  upload_concurrency: 2
  retry_failed_uploads: true
  retry_concurrency: 1
  max_retries: 2
  retry_delay_seconds: 30
  # 從 immich CLI 文字輸出解析統計，寫入 log_dir/stats/*.json
  json_output: true
  debounce_seconds: 30
  log_dir: ~/Library/Logs/immich-photo-sync
  delete_policy: none          # none | conservative（--apply 需 conservative）
  reconcile:
    enabled: false
    scope: albums              # albums | tags | both
    immich_tags: []
    include_mac_uploads: true  # UUID 檔名上傳（即使未掛相簿）
    photos_db_libraries:       # icloud：以 Photos.sqlite 判斷（purge 後才算刪除）
      - icloud-primary
    fetch_page_size: 500
    batch_size: 100
    grace_days: 0              # 0 = orphan 一經確認即可 --apply；>0 寫入 orphan-grace-state.json
    action: trash
    auto_apply: false          # true + delete_policy=conservative → watch 可自動 --apply --confirm
    schedule: "0 4 * * 0"
    watch:
      enabled: false           # M3: fswatch → debounced reconcile
      debounce_seconds: 300

# XMP sidecar（Immich CLI 上傳時自動偵測同目錄 *.xmp / *.jpg.xmp）
# 見 https://docs.immich.app/features/xmp-sidecars
# 若 originals 含 Lightroom / digiKam sidecar，metadata 會在 server Metadata Extraction job 匯入。
# 可選 glob 排除（傳給 immich upload --ignore）：
# ignore_patterns:
#   - "**/Raw/**"
#   - "**/@eaDir/**"

# Immich 備份（Phase 5 — server 端；見 docs/00_planning/BACKLOG.md）
backup_policy:
  # 3-2-1：Immich 為第 1 份；B2 為異地第 2 份；Mac .photoslibrary 為來源 SSOT
  immich_server_path: lama:/mnt/immich
  b2:
    enabled: false
    schedule: "0 3 * * *"
    retention_days: 90
