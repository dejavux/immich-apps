# Environment Variables for Immich Apps

# ═══════════════════════════════════════════════════════════════
# Immich Server
# ═══════════════════════════════════════════════════════════════
IMMICH_BASE_URL=https://immich.3q.fi
IMMICH_API_KEY=your-immich-api-key-here

# ═══════════════════════════════════════════════════════════════
# LINE Bot
# ═══════════════════════════════════════════════════════════════
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_ACCESS_TOKEN=your-line-access-token

# ═══════════════════════════════════════════════════════════════
# OpenAI (AI Annotation)
# ═══════════════════════════════════════════════════════════════
OPENAI_API_KEY=your-openai-api-key

# ═══════════════════════════════════════════════════════════════
# LINE Bot Server
# ═══════════════════════════════════════════════════════════════
PORT=3000
NODE_ENV=development

# ═══════════════════════════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════════════════════════
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════
# Port-Forward
# ═══════════════════════════════════════════════════════════════
PF_LOCAL_LINE_BOT_PORT=30430

# ═══════════════════════════════════════════════════════════════
# Kubernetes
# ═══════════════════════════════════════════════════════════════
K8S_NAMESPACE=immich

# ═══════════════════════════════════════════════════════════════
# Docker Registry
# ═══════════════════════════════════════════════════════════════
REGISTRY=registry.3q.fi
IMAGE_TAG=latest
