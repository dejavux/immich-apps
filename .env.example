# Environment Variables for Immich Apps

# ═══════════════════════════════════════════════════════════════
# Immich Server
# ═══════════════════════════════════════════════════════════════
IMMICH_BASE_URL=https://immich.3q.fi
# 勿填 placeholder — direnv 會覆蓋 1Password。Photo sync / dev 請用:
#   eval "$(./scripts/dev/load-env-from-op.sh)"
# 或刪除下行，讓腳本自動從 1Password 載入。
# IMMICH_API_KEY=

# ═══════════════════════════════════════════════════════════════
# LINE Bot
# ═══════════════════════════════════════════════════════════════
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-access-token
# alias: LINE_ACCESS_TOKEN=

# ═══════════════════════════════════════════════════════════════
# LIFF + Passkey（Immich 相簿中心）
# ═══════════════════════════════════════════════════════════════
# LINE Login channel → LIFF Endpoint: https://immich-bot.3q.fi/liff/hub
# LIFF_ID=
# LINE_LOGIN_CHANNEL_ID=
# AUTH_SESSION_SECRET=          # 預設 fallback LINE_CHANNEL_SECRET
# ADMIN_LINE_USER_IDS=Uxxx      # Immich 管理員 LINE userId（逗號分隔）
# WEBAUTHN_RP_ID=3q.fi            # 建議與對外網域一致
# WEBAUTHN_RP_NAME=Immich LINE
# REDIS_URL=                    # 選填；Passkey 持久化（未設則記憶體）
# IMMICH_WEB_URL=https://immich.3q.fi
# LINE_BOT_PUBLIC_URL=https://immich-bot.3q.fi

# ═══════════════════════════════════════════════════════════════
# OpenAI (AI Annotation)
# ═══════════════════════════════════════════════════════════════
OPENAI_API_KEY=your-openai-api-key

# ═══════════════════════════════════════════════════════════════
# LINE Bot Server
# ═══════════════════════════════════════════════════════════════
PORT=3000
NODE_ENV=development

# ═══════════════════════════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════════════════════════
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════
# Port-Forward
# ═══════════════════════════════════════════════════════════════
PF_LOCAL_LINE_BOT_PORT=30450
PF_LOCAL_IMMICH_SERVER_PORT=30451
PF_LOCAL_IMMICH_ML_PORT=30452
PF_LOCAL_IMMICH_POSTGRES_PORT=30453
PF_LOCAL_IMMICH_REDIS_PORT=30454

# ═══════════════════════════════════════════════════════════════
# Kubernetes
# ═══════════════════════════════════════════════════════════════
K8S_NAMESPACE=immich

# ═══════════════════════════════════════════════════════════════
# Docker Registry
# ═══════════════════════════════════════════════════════════════
REGISTRY=registry-internal.3q.fi
# release 映像 tag 由 make release 自動取 git short SHA，勿在此設定 IMAGE_TAG

# ═══════════════════════════════════════════════════════════════
# Cursor SDK（make lint / commit / pull_request）
# ═══════════════════════════════════════════════════════════════
# 取得 API key: https://cursor.com/dashboard/cloud-agents
CURSOR_API_KEY=
# 建議 default（勿用 composer-2.5，易 Agent status error）
CURSOR_MODEL=default
