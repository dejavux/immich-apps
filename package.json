{
  "name": "immich-apps",
  "version": "0.1.0",
  "description": "Immich complete apps: server + LINE Bot + photo sync",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "main": "src/line-bot/index.ts",
  "scripts": {
    "dev": "nodemon --exec ts-node src/line-bot/index.ts",
    "build": "tsc",
    "start": "node dist/line-bot/index.js",
    "test": "jest",
    "lint": "eslint src eslint.config.mjs",
    "lint:fix": "eslint src eslint.config.mjs --fix",
    "type-check": "tsc --noEmit",
    "type-check:planner": "npm run typecheck -w @family-memories/planner-schema && npm run typecheck -w @family-memories/planner",
    "test:planner": "jest --roots apps/planner",
    "planner:dev": "npm run dev -w @family-memories/planner",
    "format": "prettier --write \"**/*.{ts,json,yaml,yml,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,yaml,yml,md}\"",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"!node_modules/**\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\" \"!node_modules/**\" && python3 scripts/fix-markdown-tables.py",
    "lint:md:check": "markdownlint-cli2 \"**/*.md\" \"!node_modules/**\"",
    "spellcheck": "cspell lint .",
    "spellcheck:md": "cspell --no-progress --no-summary \"**/*.md\"",
    "openapi:fetch": "bash scripts/openapi/fetch-spec.sh",
    "openapi:generate": "bash scripts/openapi/generate-types.sh",
    "openapi:sync": "npm run openapi:fetch && npm run openapi:generate"
  },
  "keywords": [
    "immich",
    "line-bot",
    "photo-management",
    "ai-annotation"
  ],
  "author": "Infrastructure Team",
  "license": "MIT",
  "dependencies": {
    "@family-memories/planner": "*",
    "@family-memories/planner-schema": "*",
    "@line/bot-sdk": "^9.3.0",
    "@simplewebauthn/server": "^13.1.2",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "exifr": "^7.1.3",
    "express": "^4.21.2",
    "form-data": "^4.0.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.1.3",
    "redis": "^4.7.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "cspell": "^10.0.0",
    "eslint": "^9.18.0",
    "jest": "^29.7.0",
    "markdownlint-cli2": "^0.22.1",
    "nodemon": "^3.1.9",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
