{
  "name": "immich-apps",
  "version": "0.1.0",
  "description": "Immich complete apps: server + LINE Bot + photo sync",
  "main": "src/line-bot/index.ts",
  "scripts": {
    "dev": "nodemon --exec ts-node src/line-bot/index.ts",
    "build": "tsc",
    "start": "node dist/line-bot/index.js",
    "test": "jest",
    "lint": "eslint src eslint.config.mjs",
    "lint:fix": "eslint src eslint.config.mjs --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,json,yaml,yml,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,yaml,yml,md}\"",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"!node_modules/**\"",
    "lint:md:check": "markdownlint-cli2 \"**/*.md\" \"!node_modules/**\"",
    "spellcheck": "cspell lint .",
    "spellcheck:md": "cspell --no-progress --no-summary \"**/*.md\""
  },
  "keywords": [
    "immich",
    "line-bot",
    "photo-management",
    "ai-annotation"
  ],
  "author": "Infrastructure Team",
  "license": "MIT",
  "dependencies": {
    "@line/bot-sdk": "^9.3.0",
    "express": "^4.21.2",
    "axios": "^1.7.9",
    "form-data": "^4.0.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "dotenv": "^16.4.7",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/express": "^5.0.0",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.18.0",
    "typescript-eslint": "^8.19.1",
    "prettier": "^3.4.2",
    "markdownlint-cli2": "^0.17.1",
    "cspell": "^10.0.0",
    "typescript": "^5.7.3",
    "ts-node": "^10.9.2",
    "nodemon": "^3.1.9",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.14",
    "ts-jest": "^29.2.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
