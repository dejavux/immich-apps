{
  "name": "immich-apps",
  "version": "0.1.0",
  "description": "Immich complete apps: server + LINE Bot + photo sync",
  "main": "src/line-bot/index.ts",
  "scripts": {
    "dev": "nodemon --exec ts-node src/line-bot/index.ts",
    "build": "tsc",
